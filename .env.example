# Copy to .env for local testing. Không commit file .env thật.
# Trên GitHub Actions dùng Secrets thay vì .env.

# Telegram bot (tạo qua @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AAABBBccc...
TELEGRAM_CHAT_ID=-1001234567890

# Gemini API key (chỉ cho weekly report; daily không cần)
# Lấy tại https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Bật dry-run để không gửi Telegram thật (in ra console thay vì gửi)
DRY_RUN=1
